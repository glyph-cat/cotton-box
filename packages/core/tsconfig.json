{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "cotton-box": [
        "./src/index.ts"
      ]
    },
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "stripInternal": true,
    "target": "esnext",
    "types": [
      "node",
      "jest",
    ],
  },
}