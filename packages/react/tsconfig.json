{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "cotton-box": [
        "../core/src/index.ts"
      ],
      "cotton-box-react": [
        "./src/index.ts"
      ]
    },
    "rootDir": "..",
    "skipLibCheck": true,
    "strict": true,
    "stripInternal": true,
    "target": "esnext",
    "types": [
      "node",
      "jest",
    ],
  },
}