{
  "name": "cotton-box",
  "version": "1.0.0",
  "description": "Minimal state management library for React and beyond.",
  "main": "lib/cjs/index.js",
  "module": "lib/es/index.js",
  "react-native": "lib/native/index.js",
  "unpkg": "lib/umd/index.js",
  "files": [
    "lib"
  ],
  "types": "lib/types/index.d.ts",
  "scripts": {
    "clean": "rm -rf ./lib ./temp/tsc",
    "lint": "eslint .",
    "debug": "cross-env SCOPE=\"debug\" jest -c ./jest.config.ts",
    "bundle": "rollup -c ./config/rollup.config.js",
    "types": "yarn tsc --declaration",
    "api": "api-extractor run -c ./config/api-extractor.json --local --verbose",
    "build": "sh ./scripts/run/build.sh",
    "test": "cross-env SCOPE=\"bundled\" jest -c ./jest.config.ts",
    "prepack": "tsx ./scripts/run/sync-package",
    "all": "sh ./scripts/run/all.sh"
  },
  "keywords": [
    "State management"
  ],
  "author": "glyph-cat",
  "readme": "README.md",
  "license": "MIT",
  "homepage": "https://glyph-cat.github.io/cotton-box",
  "repository": {
    "type": "git",
    "url": "https://github.com/glyph-cat/cotton-box.git"
  },
  "bugs": {
    "url": "https://github.com/glyph-cat/cotton-box/issues"
  },
  "dependencies": {
    "@glyph-cat/foundation": "0.0.0-experimental.89",
    "@glyph-cat/type-checking": "^1.0.0"
  }
}